{
  "name": "litebi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.js\"",
    "electron:build": "vite build && electron-builder"
  },
  "main": "electron/main.js",
  "dependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@lucide/vue": "^1.17.0",
    "alasql": "^4.17.3",
    "codemirror": "^6.0.2",
    "echarts": "^6.1.0",
    "echarts-stat": "^1.2.0",
    "gridstack": "^12.6.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "localforage": "^1.10.0",
    "marked": "^18.0.5",
    "papaparse": "^5.5.3",
    "pinia": "^3.0.2",
    "pptxgenjs": "^4.0.1",
    "tabulator-tables": "^6.4.0",
    "vue": "^3.5.16",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.1.3",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5",
    "y-protocols": "^1.0.7",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.31"
