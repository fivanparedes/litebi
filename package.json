    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.10"
  }
